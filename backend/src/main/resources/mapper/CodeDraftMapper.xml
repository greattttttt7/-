<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.oslab.mapper.CodeDraftMapper">
    <resultMap id="DraftMap" type="com.example.oslab.entity.CodeDraft">
        <id column="draft_id" property="draftId" />
        <result column="user_id" property="userId" />
        <result column="lab_id" property="labId" />
        <result column="code_content" property="codeContent" />
        <result column="update_time" property="updateTime" />
    </resultMap>

    <select id="selectByUserIdAndLabId" resultMap="DraftMap">
        select * from code_draft where user_id = #{userId} and lab_id = #{labId} limit 1
    </select>

    <insert id="upsert" parameterType="com.example.oslab.entity.CodeDraft" useGeneratedKeys="true" keyProperty="draftId">
        insert into code_draft (user_id, lab_id, code_content, update_time)
        values (#{userId}, #{labId}, #{codeContent}, now())
        on duplicate key update
        code_content = values(code_content),
        update_time = now()
    </insert>
</mapper>
