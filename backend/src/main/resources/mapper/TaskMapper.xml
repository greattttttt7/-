<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.oslab.mapper.TaskMapper">
    <resultMap id="TaskMap" type="com.example.oslab.entity.Task">
        <id column="task_id" property="taskId" />
        <result column="lab_id" property="labId" />
        <result column="task_name" property="taskName" />
        <result column="file_path" property="filePath" />
        <result column="answer_path" property="answerPath" />
        <result column="line_start" property="lineStart" />
        <result column="line_end" property="lineEnd" />
        <result column="todo_content" property="todoContent" />
    </resultMap>

    <select id="selectByLabId" resultMap="TaskMap">
        select * from task where lab_id = #{labId} order by task_id
    </select>

    <select id="selectById" resultMap="TaskMap">
        select * from task where task_id = #{taskId} limit 1
    </select>
</mapper>
